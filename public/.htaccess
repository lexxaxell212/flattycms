RewriteEngine On
Header always edit Set-Cookie (.*) "$1; Secure; HttpOnly; SameSite=Lax"

RewriteRule ^assets/ - [L,NC]
RewriteRule ^config/ - [L,NC]
RewriteRule ^api/ - [L,NC]
RewriteRule ^errors/ - [L,NC]

# Admin routing
RewriteRule ^admin/login\.php$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^admin(/.*)?$ admin/index.php [L]

# Block myphpnuke & PostNuke paths
RedirectMatch 403 ^/myphpnuke/.*$
RedirectMatch 403 ^/modules\.php.*$

ErrorDocument 404 /errors/404.php
ErrorDocument 403 /errors/403.php
ErrorDocument 500 /errors/500.php

RewriteCond %{REQUEST_URI} ^/pages/ [NC]
RewriteRule ^(.*)$ index.php [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L]